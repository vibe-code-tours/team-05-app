# ─── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Database (Supabase) ────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode for server-side, "Session" mode for pooled connections
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── Auth ───────────────────────────────────────────────
# REQUIRED: At least 32 characters. Generate with: openssl rand -base64 48
# The app will NOT start if this is missing or is the default value.
JWT_SECRET=your_secure_random_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Supabase ───────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Cloudflare R2 (Object Storage) ─────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=crossmart-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Redis (Upstash - Free) ─────────────────────────────
# Get from: Upstash Console → Redis → Endpoint
REDIS_URL=redis://default:xxxxx@xxxxx.upstash.io:6379

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
